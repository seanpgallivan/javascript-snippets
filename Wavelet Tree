// Wavelet Tree implementation
class WaveletTree  {
    constructor(arr, lo=null, hi=null, expand=null) {
        this.lo
        if (lo === null) {
            // O(n + α log α): Force rank substitution
            expand = this.compress(arr), lo = 0, hi = expand.length - 1
            this.lo = expand[lo]
            if (!hi)
                return
        } else if (lo === hi) {
            this.lo = expand?.[lo] ?? lo
            return
        } else
            this.lo = expand?.[lo] ?? lo
        this.hi = expand?.[hi] ?? hi
        this.leftCount = new Uint32Array(arr.length + 1)
        // Next line only needed for sum functions
        this.prefixSum = new Array(arr.length + 1).fill(0,0,1)
        this.left
        this.right
        this.build(arr, lo, hi, expand)
    }
    compress(arr) {
        // O(n + α log α): Compress arr values by rank
        const expand = Uint32Array.from(new Set(arr)).sort()
        if (expand.length > 1) {
            const compress = expand.reduce((a,c,i) => a.set(c, i), new Map())
            for (let i = arr.length - 1; ~i; i--)
                arr[i] = compress.get(arr[i])
        }
        return expand
    }
    build(arr, lo, hi, expand) {
        // O(n): Split arr in half by alphabet size, update data, & recurse
        const n = arr.length, mid = lo + hi >> 1, leftArr = [], rightArr = []
        for (let i = 0; i < n; i++) {
            if (arr[i] > mid)
                rightArr.push(arr[i]), this.leftCount[i + 1] = this.leftCount[i]
            else
                leftArr.push(arr[i]), this.leftCount[i + 1] = this.leftCount[i] + 1
            // Next line only needed for sum functions
            this.prefixSum[i + 1] = this.prefixSum[i] + (expand?.[arr[i]] ?? arr[i])
        }
        if (leftArr.length)
            this.left = new WaveletTree(leftArr, lo, mid, expand)
        if (rightArr.length)
            this.right = new WaveletTree(rightArr, mid + 1, hi, expand)
    }
    kthOfRange(k, l=0, r=this.leftCount.length - 2) {
        // O(log α): Find range quantile
        if (this.hi === undefined)
            return this.lo
        const lcLeft = this.leftCount[l], lcRight = this.leftCount[r + 1],
              lcRange = lcRight - lcLeft
        return k <= lcRange
            ? this.left.kthOfRange(k, lcLeft, lcRight - 1)
            : this.right.kthOfRange(k - lcRange, l - lcLeft, r - lcRight)
    }
    rangeMin(l=0, r=this.leftCount.length - 2) {
        // O(log α): Find the smallest value in range
        return this.kthOfRange(r - l + 1, l, r)
    }
    rangeMax(l=0, r=this.leftCount.length - 2) {
        // O(log α): Find the largest value in range
        return this.kthOfRange(1, l, r)
    }
    rangeMedian(l=0, r=this.leftCount.length - 2) {
        // O(log α): Find the median value in range
        return this.kthOfRange(r - l + 2 >> 1, l, r)
    }
    rangeCountKOrLess(k, l=0, r=this.leftCount.length - 2) {
        // O(log α): Find count of the values k or less in range
        if (k < this.lo)
            return 0
        if (this.hi === undefined || k >= this.hi)
            return r - l + 1
        const lCl = this.leftCount[l], lCr = this.leftCount[r + 1]
        return k >= this.right?.lo
            ? lCr - lCl + this.right.rangeCountKOrLess(k, l - lCl, r - lCr)
            : lCr - lCl
                ? this.left.rangeCountKOrLess(k, lCl, lCr - 1)
                : 0
    }
    
    // this.prefixSum necessary for sum functions to work
    rangeSumLeastK(k, l=0, r=this.leftCount.length - 2) {
        // O(log α): Find sum of the k smallest values in range
        if (r < l || k < 1)
            return 0
        if (this.hi === undefined)
            return this.lo * Math.min(k, r - l + 1)
        if (k > r - l)
            return this.prefixSum[r + 1] - this.prefixSum[l]
        const lCl = this.leftCount[l], lCr = this.leftCount[r + 1]
        return (this.left?.rangeSumLeastK(k, lCl, lCr - 1) ?? 0)
             + (this.right?.rangeSumLeastK(k - (lCr - lCl), l - lCl, r - lCr) ?? 0)
    }
    rangeSum(k, l=0, r=this.leftCount.length - 2) {
        // O(log α): Find sum of all values in range
        return this.rangeSumLeastK(r - l + 1, l, r)
    }
    rangeSumKOrLess(k, l=0, r=this.leftCount.length - 1) {
        // O(log α): Find sum of the values k or less in range
        if (r < l || k < this.lo)
            return 0
        if (this.hi === undefined)
            return this.lo * (r - l + 1)
        if (k >= this.hi)
            return this.prefixSum[r + 1] - this.prefixSum[l]
        const lCl = this.leftCount[l], lCr = this.leftCount[r + 1]
        return (this.left?.rangeSumKOrLess(k, lCl, lCr - 1) ?? 0)
             + (this.right?.rangeSumKOrLess(k, l - lCl, r - lCr) ?? 0)
    }
}




