const getRan = (cap, start=0) => start + ~~(Math.random() * (cap - start))

const arr = []
const foo = new WaveletTree([...arr])
const k = 9, l = 47, r = 70

console.log(foo.kthOfRange(k, l, r))
console.log(arr.slice(l, r + 1).sort((a,b) => a - b)[k - 1])
console.log(foo.rangeSumLeastK(k, l, r))
console.log(" ->",arr.slice(l, r + 1).sort((a,b) => a - b).slice(0, k).reduce((a,c) => a + c, 0))
console.log(foo.rangeCountKOrLess(k,l,r))
console.log(" ->",arr.slice(l, r + 1).sort((a,b) => a - b).filter(x => x <= k).reduce((a,c) => a + 1, 0))
console.log(foo.rangeSumKOrLess(k,l,r))
console.log(" ->",arr.slice(l, r + 1).sort((a,b) => a - b).filter(x => x <= k).reduce((a,c) => a + c, 0))

const test = (trees, tests, nmax, vmax) => {
    let res1, res2
