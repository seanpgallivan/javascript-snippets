        const n = getRan(nmax, 5),
              v = getRan(vmax, 5)
        const arr = []
        for (let a = 0; a < n; a++)
            arr.push(getRan(v))
        const sorted = Uint32Array.from(arr).sort()
        const foo = new WaveletTree([...arr])
        const bar = new WaveletTree([...arr], 0, v)
        for (let t = 0; t < tests; t++) {
            let err = 0
            const ki = getRan(n),
                  kv = getRan(v),
                  l = getRan(n - (n >> 4)),
                  r = getRan(n, l)
            
            res1 = foo.rangeCountKOrLess(kv, l, r),
            res2 = arr.slice(l, r + 1).sort((a,b) => a - b).filter(x => x <= kv).reduce((a,c) => a + 1, 0)
            if (res1 !== res2)
                console.log("n,v",[n,v],"  --> k,l,r",[kv,l,r],"  --> foo count-k-less error",++err,"!  ", res1, res2)
            
            res1 = foo.rangeSumKOrLess(kv, l, r),
