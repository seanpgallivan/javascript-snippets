                console.log("n,v",[n,v],"  --> k,l,r",[kv,l,r],"  --> foo sum-k-less error",++err,"!  ", res1, res2)
            
            res1 = foo.rangeSumLeastK(ki, l, r),
            res2 = arr.slice(l, r + 1).sort((a,b) => a - b).slice(0, ki).reduce((a,c) => a + c, 0)
            if (res1 !== res2)
                console.log("n,v",[n,v],"  --> k,l,r",[ki,l,r],"  --> foo sum-least-k error",++err,"!  ", res1, res2)
            
            res1 = bar.rangeCountKOrLess(kv, l, r),
            res2 = arr.slice(l, r + 1).sort((a,b) => a - b).filter(x => x <= kv).reduce((a,c) => a + 1, 0)
            if (res1 !== res2)
                console.log("n,v",[n,v],"  --> k,l,r",[kv,l,r],"  --> bar count-k-less error",++err,"!  ", res1, res2)
            
            res1 = bar.rangeSumKOrLess(kv, l, r),
            res2 = arr.slice(l, r + 1).sort((a,b) => a - b).filter(x => x <= kv).reduce((a,c) => a + c, 0)
            if (res1 !== res2)
